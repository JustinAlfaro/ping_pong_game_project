### Hog .gitignore ###
# IP: solo se versiona el .xci, no los archivos generados
IP/*/*
!IP/*/*.xci*

# BD: se versiona el .bd + XCI de IPs + archivos de configuración (.prj para MIG)
BD/*
!BD/*.bd
!BD/ip/
BD/ip/*/*
!BD/ip/*/*.xci
!BD/ip/*/*.prj

